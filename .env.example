# --- Database ---
DATABASE_URL=postgresql://salila:salila@localhost:5432/salila_muha

# --- Supabase (auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000        # local: MinIO | prod: leave blank for AWS
S3_BUCKET=salila-muha
S3_REGION=af-south-1
S3_ACCESS_KEY=salila
S3_SECRET_KEY=salila123

# --- Email (SMTP) ---
SMTP_HOST=localhost                      # local: mailpit | prod: smtp.gmail.com
SMTP_PORT=1025                           # local: 1025    | prod: 587
SMTP_USER=                               # prod only: your Gmail address
SMTP_PASS=                               # prod only: Google app password
SMTP_FROM=no-reply@salilamuha.co.za

# --- Payments ---
YOCO_SECRET_KEY=sk_test_your_key
YOCO_PUBLIC_KEY=pk_test_your_key

# --- API ---
PORT=3001
JWT_SECRET=change_me_in_production
NODE_ENV=development

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_YOCO_PUBLIC_KEY=pk_test_your_key
