# --- Database ---
DATABASE_URL=postgresql://salila:salila@localhost:5432/salila_muha

# --- Supabase (auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000        # local: MinIO | prod: leave blank for AWS
S3_BUCKET=salila-muha
S3_REGION=af-south-1
S3_ACCESS_KEY=salila
S3_SECRET_KEY=salila123

# --- Email (SMTP) ---
SMTP_HOST=localhost                      # local: mailpit | prod: smtp.gmail.com
SMTP_PORT=1025                           # local: 1025    | prod: 587
SMTP_USER=                               # prod only: your Gmail address
SMTP_PASS=                               # prod only: Google app password
SMTP_FROM=no-reply@salilamuha.co.za

# --- SMS (Africa's Talking) ---
AT_USERNAME=sandbox                      # use "sandbox" for testing
AT_API_KEY=your_at_api_key
AT_SENDER_ID=                            # optional, leave blank or set e.g. SALILAMUHA

# --- Payments (PayFast) ---
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_SANDBOX=true                     # true for sandbox, false for live
FRONTEND_URL=https://salila-muha.vercel.app
BACKEND_URL=http://13.244.64.123

# --- API ---
PORT=3001
JWT_SECRET=change_me_in_production
NODE_ENV=development

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
